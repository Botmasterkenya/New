<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>MindCare App — All Screens</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --mint:#1D9E75;--mint-d:#0F6E56;--mint-l:#E1F5EE;--mint-m:#5DCAA5;
  --purple:#534AB7;--purple-l:#EEEDFE;--purple-m:#AFA9EC;
  --amber:#BA7517;--amber-l:#FAEEDA;
  --red:#E24B4A;--red-l:#FCEBEB;
  --gray:#F7F9F8;--border:#e2e8f0;--text:#111827;--muted:#6b7280;
}
body{font-family:'Plus Jakarta Sans',sans-serif;background:#f0f4f8;color:var(--text);padding:40px 24px;min-height:100vh}
h1{text-align:center;font-size:28px;font-weight:800;color:var(--text);margin-bottom:6px}
.subtitle{text-align:center;font-size:14px;color:var(--muted);margin-bottom:48px}
.section{margin-bottom:64px}
.section-title{font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);text-align:center;margin-bottom:6px}
.section-name{font-size:22px;font-weight:800;text-align:center;margin-bottom:28px;color:var(--text)}
.phones-row{display:flex;gap:28px;justify-content:center;flex-wrap:wrap;align-items:flex-start}
.phone-wrap{display:flex;flex-direction:column;align-items:center;gap:10px}
.screen-label{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.4px;background:#fff;border:1px solid var(--border);padding:4px 12px;border-radius:20px}
.phone{width:240px;min-height:480px;background:#fff;border-radius:36px;border:3px solid #cbd5e1;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.1)}
.sbar{padding:10px 18px 4px;display:flex;justify-content:space-between;align-items:center;font-size:10px;font-weight:700;flex-shrink:0}
 
/* NAV BAR */
.nav-bar{background:#fff;border-top:1px solid var(--border);display:flex;padding:8px 0 10px;flex-shrink:0}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer}
.nav-item svg{width:18px;height:18px;stroke:var(--muted);fill:none;stroke-width:1.8}
.nav-item span{font-size:8px;color:var(--muted);font-weight:600}
.nav-item.active svg{stroke:var(--mint)}
.nav-item.active span{color:var(--mint)}
 
/* ===== SCREEN 1: SPLASH ===== */
.splash{flex:1;background:linear-gradient(165deg,var(--mint-d) 0%,var(--mint) 60%,var(--mint-m) 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;padding:28px}
.splash .logo-box{width:68px;height:68px;background:rgba(255,255,255,.15);border-radius:20px;border:1.5px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center}
.splash .app-name{color:#fff;font-size:24px;font-weight:800;letter-spacing:-.5px}
.splash .tagline{color:rgba(255,255,255,.75);font-size:11px;text-align:center;line-height:1.6;max-width:160px}
.splash .cta{background:#fff;color:var(--mint-d);border:none;padding:12px 36px;border-radius:22px;font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;font-weight:700;margin-top:8px}
.splash .link{color:rgba(255,255,255,.65);font-size:10px;text-decoration:underline}
 
/* ===== SCREEN 2: ONBOARDING ===== */
.ob-img{height:180px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ob-body{flex:1;background:#fff;border-radius:22px 22px 0 0;padding:18px}
.ob-body h3{font-size:16px;font-weight:800;margin-bottom:6px}
.ob-body p{font-size:11px;color:var(--muted);line-height:1.6}
.dots{display:flex;gap:5px;margin:12px 0}
.dot{width:6px;height:6px;border-radius:3px;background:#d1d5db}
.dot.on{width:18px}
.ob-btn{width:100%;border:none;padding:11px;border-radius:12px;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:700;color:#fff}
 
/* ===== SCREEN 3: LOGIN ===== */
.login-body{flex:1;padding:20px 18px;display:flex;flex-direction:column;justify-content:center;gap:10px}
.login-logo{display:flex;align-items:center;gap:8px;margin-bottom:4px}
.login-logo-icon{width:32px;height:32px;background:var(--mint-l);border-radius:10px;display:flex;align-items:center;justify-content:center}
.login-body h2{font-size:18px;font-weight:800}
.login-body .sub{font-size:11px;color:var(--muted);margin-top:-4px}
.field{width:100%;background:var(--gray);border:1.5px solid var(--border);border-radius:10px;padding:10px 12px;font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;color:var(--text);outline:none}
.field:focus{border-color:var(--mint)}
.forgot{text-align:right;font-size:10px;color:var(--mint);font-weight:600;margin-top:-4px}
.login-btn{background:var(--mint);color:#fff;border:none;width:100%;padding:11px;border-radius:12px;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:700}
.divider{display:flex;align-items:center;gap:8px;font-size:10px;color:#9ca3af}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border)}
.soc-row{display:flex;gap:8px}
.soc-btn{flex:1;border:1.5px solid var(--border);border-radius:10px;padding:8px;font-size:10px;font-weight:600;color:var(--text);text-align:center;background:#fff}
.register-link{text-align:center;font-size:10px;color:var(--muted)}
.register-link span{color:var(--mint);font-weight:700}
 
/* ===== SCREEN 4: HOME DASHBOARD ===== */
.home-header{background:var(--mint);padding:16px 16px 20px;flex-shrink:0}
.home-header .greeting{color:rgba(255,255,255,.8);font-size:11px}
.home-header .name{color:#fff;font-size:20px;font-weight:800;margin-top:2px}
.streak-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.2);border-radius:12px;padding:4px 10px;margin-top:8px}
.streak-badge span{color:#fff;font-size:10px;font-weight:600}
.home-body{flex:1;padding:12px;overflow:hidden}
.sec-title{font-size:9px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;margin-bottom:8px}
.progress-bar{background:#e5e7eb;border-radius:6px;height:6px;margin-bottom:14px}
.progress-fill{background:var(--mint);height:6px;border-radius:6px}
.med-card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:10px 12px;display:flex;align-items:center;gap:10px;margin-bottom:8px}
.med-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.med-info{flex:1}
.med-name{font-size:12px;font-weight:600}
.med-time{font-size:10px;color:var(--muted);margin-top:1px}
.check-done{width:26px;height:26px;border-radius:50%;background:var(--mint);display:flex;align-items:center;justify-content:center;border:none;flex-shrink:0}
.check-empty{width:26px;height:26px;border-radius:50%;border:2px solid var(--border);background:none;flex-shrink:0}
.mood-quick{display:flex;gap:6px;margin-top:2px}
.mq{flex:1;background:#fff;border:1.5px solid var(--border);border-radius:10px;padding:6px 4px;text-align:center;font-size:16px}
.mq.sel{border-color:var(--mint);background:var(--mint-l)}
 
/* ===== SCREEN 5: MEDICATION LOG ===== */
.log-header{background:#fff;padding:14px 16px;border-bottom:1px solid var(--border);flex-shrink:0}
.log-header h2{font-size:16px;font-weight:800}
.log-header p{font-size:10px;color:var(--muted);margin-top:1px}
.log-body{flex:1;padding:12px;overflow:hidden}
.time-group{margin-bottom:14px}
.time-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);margin-bottom:6px;display:flex;align-items:center;gap:6px}
.time-lbl::after{content:'';flex:1;height:1px;background:var(--border)}
.log-row{background:#fff;border:1px solid var(--border);border-radius:10px;padding:9px 12px;display:flex;align-items:center;gap:8px;margin-bottom:5px}
.dot8{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.log-name{flex:1;font-size:11px;font-weight:600}
.tag{font-size:9px;padding:3px 8px;border-radius:7px;font-weight:700}
.tag-t{background:var(--mint-l);color:var(--mint-d)}
.tag-s{background:#FEF3C7;color:#92400E}
.tag-u{background:#F1F5F9;color:#64748b}
.add-med{width:100%;background:var(--mint-l);border:1.5px dashed var(--mint-m);border-radius:10px;padding:9px;font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;font-weight:600;color:var(--mint);margin-top:6px}
 
/* ===== SCREEN 6: MOOD TRACKER ===== */
.mood-header{background:var(--purple);padding:14px 16px 16px;flex-shrink:0}
.mood-header h2{color:#fff;font-size:16px;font-weight:800}
.mood-header p{color:rgba(255,255,255,.7);font-size:10px;margin-top:2px}
.mood-body{flex:1;padding:12px;overflow:hidden}
.mood-scale{display:flex;gap:5px;margin-bottom:14px}
.mface{flex:1;background:#fff;border:1.5px solid var(--border);border-radius:10px;padding:7px 3px;text-align:center}
.mface.active{border-color:var(--purple);background:var(--purple-l)}
.mface .em{font-size:18px;display:block;margin-bottom:1px}
.mface .ml{font-size:8px;color:var(--muted)}
.journal{width:100%;background:#fff;border:1.5px solid var(--border);border-radius:10px;padding:10px;font-family:'Plus Jakarta Sans',sans-serif;font-size:10px;resize:none;height:60px;outline:none;color:var(--text)}
.week-chart{background:#fff;border:1px solid var(--border);border-radius:12px;padding:10px 12px;margin-top:12px}
.bars{display:flex;align-items:flex-end;gap:4px;height:44px;margin-top:6px}
.bar{flex:1;border-radius:3px 3px 0 0;background:var(--purple-l);min-height:4px}
.bar.today{background:var(--purple)}
.blab{display:flex;gap:4px;margin-top:3px}
.blab span{flex:1;text-align:center;font-size:8px;color:var(--muted)}
.save-btn{width:100%;background:var(--purple);color:#fff;border:none;padding:10px;border-radius:12px;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:700;margin-top:10px}
 
/* ===== SCREEN 7: ADD MEDICATION ===== */
.form-header{background:#fff;padding:14px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0}
.back-btn{width:28px;height:28px;border-radius:8px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;background:none}
.form-header h2{font-size:15px;font-weight:800;flex:1}
.form-body{flex:1;padding:14px;overflow:hidden;display:flex;flex-direction:column;gap:10px}
.form-label{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:.4px;margin-bottom:4px}
.form-field{width:100%;background:var(--gray);border:1.5px solid var(--border);border-radius:10px;padding:9px 12px;font-family:'Plus Jakarta Sans',sans-serif;font-size:11px;color:var(--text);outline:none}
.form-row{display:flex;gap:8px}
.freq-chips{display:flex;gap:5px;flex-wrap:wrap;margin-top:2px}
.chip{padding:5px 10px;border:1.5px solid var(--border);border-radius:18px;font-size:10px;font-weight:600;color:var(--muted);background:#fff}
.chip.on{border-color:var(--mint);background:var(--mint-l);color:var(--mint-d)}
.save-med{width:100%;background:var(--mint);color:#fff;border:none;padding:11px;border-radius:12px;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:700;margin-top:auto}
 
/* ===== SCREEN 8: INSIGHTS ===== */
.insights-header{background:#fff;padding:14px 16px;border-bottom:1px solid var(--border);flex-shrink:0}
.insights-header h2{font-size:16px;font-weight:800}
.insights-body{flex:1;padding:12px;overflow:hidden}
.stat-row{display:flex;gap:6px;margin-bottom:10px}
.stat-box{flex:1;background:var(--gray);border-radius:10px;padding:8px 10px;border:1px solid var(--border)}
.stat-val{font-size:18px;font-weight:800}
.stat-lbl{font-size:9px;color:var(--muted);margin-top:1px;line-height:1.3}
.insight-card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:11px;margin-bottom:8px}
.insight-top{display:flex;align-items:center;gap:8px;margin-bottom:5px}
.insight-icon{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.insight-title{font-size:12px;font-weight:700}
.insight-sub{font-size:10px;color:var(--muted)}
.insight-body{font-size:10px;color:var(--muted);line-height:1.5}
 
/* ===== SCREEN 9: NOTIFICATIONS ===== */
.notif-header{background:#fff;padding:14px 16px;border-bottom:1px solid var(--border);flex-shrink:0}
.notif-header h2{font-size:16px;font-weight:800}
.notif-body{flex:1;padding:12px;overflow:hidden}
.notif-item{background:#fff;border:1px solid var(--border);border-radius:12px;padding:10px 12px;display:flex;align-items:flex-start;gap:10px;margin-bottom:8px}
.notif-dot{width:8px;height:8px;border-radius:50%;background:var(--mint);flex-shrink:0;margin-top:3px}
.notif-dot.purple{background:var(--purple)}
.notif-dot.amber{background:var(--amber)}
.notif-text{flex:1}
.notif-title{font-size:11px;font-weight:700}
.notif-body-text{font-size:10px;color:var(--muted);line-height:1.4;margin-top:2px}
.notif-time{font-size:9px;color:var(--muted);margin-top:3px}
 
/* ===== SCREEN 10: PROFILE ===== */
.profile-header{background:var(--mint);padding:20px 16px 24px;text-align:center;flex-shrink:0}
.avatar{width:64px;height:64px;border-radius:50%;background:rgba(255,255,255,.25);border:2.5px solid rgba(255,255,255,.5);display:flex;align-items:center;justify-content:center;margin:0 auto 8px;font-size:22px;font-weight:800;color:#fff}
.profile-name{color:#fff;font-size:16px;font-weight:800}
.profile-email{color:rgba(255,255,255,.7);font-size:10px;margin-top:2px}
.profile-body{flex:1;padding:12px;overflow:hidden}
.setting-group{margin-bottom:10px}
.setting-row{display:flex;align-items:center;padding:10px 12px;background:#fff;border:1px solid var(--border);border-radius:10px;margin-bottom:5px;gap:9px}
.s-icon{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.s-label{flex:1;font-size:11px;font-weight:600}
.s-arrow{font-size:13px;color:var(--muted)}
</style>
</head>
<body>
 
<h1>MindCare App</h1>
<div class="subtitle">Complete UI screens · Mental health & medication tracking app</div>
 
<!-- ====== SECTION 1: ONBOARDING ====== -->
<div class="section">
  <div class="section-title">Section 1</div>
  <div class="section-name">Onboarding & Authentication</div>
  <div class="phones-row">
 
    <!-- Splash -->
    <div class="phone-wrap">
      <div class="screen-label">1. Splash screen</div>
      <div class="phone">
        <div class="sbar" style="background:#0F6E56;color:#fff"><span>9:41</span><span>●●●</span></div>
        <div class="splash">
          <div class="logo-box">
            <svg width="34" height="34" viewBox="0 0 34 34" fill="none">
              <circle cx="17" cy="17" r="13" fill="rgba(255,255,255,.2)"/>
              <path d="M9 17h16M17 9v16" stroke="#fff" stroke-width="2.8" stroke-linecap="round"/>
              <circle cx="17" cy="17" r="4" fill="rgba(255,255,255,.45)"/>
            </svg>
          </div>
          <div class="app-name">MindCare</div>
          <div class="tagline">Your daily companion for medication, mood & mental wellness</div>
          <button class="cta">Get started</button>
          <div class="link">I already have an account</div>
        </div>
      </div>
    </div>
 
    <!-- Onboarding 1 -->
    <div class="phone-wrap">
      <div class="screen-label">2. Onboarding · step 1</div>
      <div class="phone">
        <div class="sbar"><span>9:41</span><span>Skip</span></div>
        <div class="ob-img" style="background:linear-gradient(135deg,#E1F5EE,#9FE1CB)">
          <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
            <rect x="16" y="26" width="56" height="44" rx="10" fill="#fff" stroke="#1D9E75" stroke-width="2"/>
            <rect x="26" y="38" width="36" height="5" rx="2.5" fill="#1D9E75"/>
            <rect x="26" y="47" width="26" height="5" rx="2.5" fill="#5DCAA5"/>
            <rect x="26" y="56" width="16" height="5" rx="2.5" fill="#9FE1CB"/>
            <circle cx="72" cy="66" r="14" fill="#1D9E75"/>
            <path d="M66 66l4 4 8-8" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="ob-body">
          <h3>Track your medications</h3>
          <p>Never miss a dose again. Set smart reminders, log every pill, and build healthy habits that stick — all in one beautiful place.</p>
          <div class="dots"><div class="dot on" style="background:var(--mint)"></div><div class="dot"></div><div class="dot"></div></div>
          <button class="ob-btn" style="background:var(--mint)">Next →</button>
        </div>
      </div>
    </div>
 
    <!-- Onboarding 2 -->
    <div class="phone-wrap">
      <div class="screen-label">3. Onboarding · step 2</div>
      <div class="phone">
        <div class="sbar"><span>9:41</span><span>Skip</span></div>
        <div class="ob-img" style="background:linear-gradient(135deg,#EEEDFE,#CECBF6)">
          <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
            <circle cx="50" cy="50" r="26" fill="#fff" stroke="#534AB7" stroke-width="2"/>
            <circle cx="42" cy="45" r="3.5" fill="#534AB7"/>
            <circle cx="58" cy="45" r="3.5" fill="#534AB7"/>
            <path d="M38 60s4 6 12 6 12-6 12-6" stroke="#534AB7" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="ob-body">
          <h3 style="color:var(--purple)">Monitor your mood daily</h3>
          <p>Log how you feel every day and discover patterns. Our AI automatically connects your mood to your treatment schedule.</p>
          <div class="dots"><div class="dot"></div><div class="dot on" style="background:var(--purple)"></div><div class="dot"></div></div>
          <button class="ob-btn" style="background:var(--purple)">Next →</button>
        </div>
      </div>
    </div>
 
    <!-- Onboarding 3 -->
    <div class="phone-wrap">
      <div class="screen-label">4. Onboarding · step 3</div>
      <div class="phone">
        <div class="sbar"><span>9:41</span><span>Skip</span></div>
        <div class="ob-img" style="background:linear-gradient(135deg,#FAEEDA,#FAC775)">
          <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
            <rect x="22" y="30" width="56" height="40" rx="10" fill="#fff" stroke="#BA7517" stroke-width="2"/>
            <path d="M30 58L40 44l10 8 10-14 10 10" stroke="#BA7517" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="30" cy="58" r="3.5" fill="#BA7517"/>
            <circle cx="70" cy="48" r="3.5" fill="#BA7517"/>
          </svg>
        </div>
        <div class="ob-body">
          <h3 style="color:var(--amber)">AI-powered insights</h3>
          <p>See trends in your health over time. Our AI spots connections between your medication, mood, sleep and daily habits.</p>
          <div class="dots"><div class="dot"></div><div class="dot"></div><div class="dot on" style="background:var(--amber)"></div></div>
          <button class="ob-btn" style="background:var(--amber)">Get started →</button>
        </div>
      </div>
    </div>
 
    <!-- Login -->
    <div class="phone-wrap">
      <div class="screen-label">5. Login screen</div>
      <div class="phone">
        <div class="sbar"><span>9:41</span><span>●●●</span></div>
        <div class="login-body">
          <div class="login-logo">
            <div class="login-logo-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9h10M9 4v10" stroke="#1D9E75" stroke-width="2.5" stroke-linecap="round"/></svg>
            </div>
            <span style="font-size:16px;font-weight:800">MindCare</span>
          </div>
          <h2>Welcome back</h2>
          <div class="sub">Sign in to your account</div>
          <input class="field" placeholder="Email address" type="email"/>
          <input class="field" placeholder="Password" type="password"/>
          <div class="forgot">Forgot password?</div>
          <button class="login-btn">Sign in</button>
          <div class="divider">or continue with</div>
          <div class="soc-row">
            <div class="soc-btn">🔵 Google</div>
            <div class="soc-btn">⚫ Apple</div>
          </div>
          <div class="register-link">New to MindCare? <span>Create account</span></div>
        </div>
      </div>
    </div>
 
  </div>
</div>
 
<!-- ====== SECTION 2: MAIN SCREENS ====== -->
<div class="section">
  <div class="section-title">Section 2</div>
  <div class="section-name">Main App Screens</div>
  <div class="phones-row">
 
    <!-- Home Dashboard -->
    <div class="phone-wrap">
      <div class="screen-label">6. Home dashboard</div>
      <div class="phone">
        <div class="sbar" style="background:var(--mint);color:#fff"><span>9:41</span><span>●●●</span></div>
        <div class="home-header">
          <div class="greeting">Good morning,</div>
          <div class="name">Sarah 👋</div>
          <div class="streak-badge">
